# =============================================================================
# No Cry Casino — production environment (KOL parimutuel prediction market)
# Copy to .env.local for dev; set the same keys in your deploy host for prod.
# Values marked (SECRET) must never be committed or exposed to the browser.
# =============================================================================

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://nocrycasino.com

# --- Supabase (new prod project: kol-prediction-market / qlfwzxrpomtsxcmvidjg) -
NEXT_PUBLIC_SUPABASE_URL=https://qlfwzxrpomtsxcmvidjg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFsZnd6eHJwb210c3hjbXZpZGpnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI2MzU0NDUsImV4cCI6MjA5ODIxMTQ0NX0.SaGkomM1MefF3Vaf1W0UvAJ3J8YkOrDB8OBsoOiapPU
# (SECRET) Supabase dashboard -> Project Settings -> API -> service_role key:
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin / ops auth (all REQUIRED in production; endpoints fail closed) -----
# (SECRET) protects every /api/admin/* money + ops endpoint
ADMIN_API_KEY=
# (SECRET) protects the cron tick /api/cron/tick (Vercel Cron auto-forwards this)
CRON_SECRET=
# (SECRET) protects POST /api/webhooks/helius (ingestion oracle source)
HELIUS_WEBHOOK_AUTH_TOKEN=
# Replay protection for signed user actions — keep ON in production
PM_REQUIRE_NONCE=true

# --- Helius / Solana RPC -----------------------------------------------------
HELIUS_API_KEY=
HELIUS_WEBHOOK_ID=
HELIUS_WEBHOOK_API_BASE_URL=https://api.helius.xyz
HELIUS_RPC_API_BASE_URL=https://api.helius.xyz
# Server-side RPC (use a paid Helius/Triton endpoint for reliable payouts)
SOLANA_RPC_URL=
# Browser RPC (can be the public endpoint)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Comma-separated fallback RPCs used if the primary fails
SOLANA_RPC_FALLBACKS=https://api.mainnet-beta.solana.com

# --- Collateral mints (markets are denominated in SOL or USDC) ---------------
# SOL is the native sentinel 'SOL' in market_rounds.collateral_mint.
# Mainnet USDC mint:
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# --- $NOCRY fee waiver (>= threshold tokens => zero rake on that bet) ---------
# REQUIRED to activate the waiver; if unset, the waiver is simply OFF.
NOCRY_MINT=
NOCRY_FEE_WAIVER_THRESHOLD=10000

# --- Fees --------------------------------------------------------------------
# Default rake for non-exempt bettors, basis points (250 = 2.5%). Stored per
# round as market_rounds.rake_bps at bootstrap.
HOUSE_FEE_BPS=250
# Wallet that receives collected protocol fees
FEE_WALLET_ADDRESS=

# --- Custodial escrow (real SOL/USDC custody) --------------------------------
# Custody mode: 'single' (hot keypair, default) or 'squads' (multisig, partial).
CUSTODY_MODE=single
# Primary PM escrow wallet (deposits land here; withdrawals send from here)
PM_ESCROW_WALLET_ADDRESS=
# Rotating escrow wallets (addresses public; secret keys SECRET, base58/json[64])
ESCROW_WALLET_1_ADDRESS=
ESCROW_WALLET_2_ADDRESS=
ESCROW_WALLET_3_ADDRESS=
# (SECRET) — generate FRESH keys for this launch; do not reuse old ones
ESCROW_WALLET_1_SECRET_KEY=
ESCROW_WALLET_2_SECRET_KEY=
ESCROW_WALLET_3_SECRET_KEY=

# --- Optional: Squads multisig custody (only if CUSTODY_MODE=squads) ----------
# SQUADS_MULTISIG_PDA=
# SQUADS_VAULT_INDEX=0
# SQUADS_PROPOSER_SECRET_KEY=   # (SECRET)

# --- Market scope ------------------------------------------------------------
# How many tracked KOLs to surface in market generation / leaderboard
MARKET_KOLS_LIMIT=200
